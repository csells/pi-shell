{
  "name": "pi-shell",
  "version": "0.1.0",
  "description": "Pi extension that makes ! and !! commands behave like a real shell — tab completion, cd tracking, aliases, explain mode, fix-on-fail",
  "type": "module",
  "license": "MIT",
  "author": "Chris Sells",
  "repository": {
    "type": "git",
    "url": "https://github.com/csells/pi-shell.git"
  },
  "keywords": ["pi-package"],
  "main": "src/index.ts",
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "dependencies": {},
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest"
  }
}
